{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/drywall-repair-las-vegas/",
      "destination": "/drywall-repair-las-vegas",
      "permanent": true
    },
    {
      "source": "/interior-painting-las-vegas/",
      "destination": "/interior-painting-las-vegas",
      "permanent": true
    },
    {
      "source": "/door-repair-las-vegas/",
      "destination": "/door-repair-las-vegas",
      "permanent": true
    },
    {
      "source": "/flooring-las-vegas/",
      "destination": "/flooring-las-vegas",
      "permanent": true
    },
    {
      "source": "/faucet-installation-las-vegas/",
      "destination": "/faucet-installation-las-vegas",
      "permanent": true
    },
    {
      "source": "/garbage-disposal-las-vegas/",
      "destination": "/garbage-disposal-las-vegas",
      "permanent": true
    },
    {
      "source": "/commercial-handyman-las-vegas/",
      "destination": "/commercial-handyman-las-vegas",
      "permanent": true
    }
  ]
}
